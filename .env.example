# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mistral (via Vercel AI SDK — reads MISTRAL_API_KEY)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Inngest — local dev only (omit INNGEST_DEV in production)
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Public app URL (invite links + GitHub webhook URL in admin UI)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to 1 on Vercel to hide full server error details in production again
# HIDE_SERVER_ERRORS=1
